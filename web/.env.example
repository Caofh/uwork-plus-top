# Remote infrastructure (optional — required for full online features)
# Example: VITE_REMOTE_ORIGIN=https://your-cdn.example.com
VITE_REMOTE_ORIGIN=

# API (defaults derived from VITE_REMOTE_ORIGIN when set)
VITE_API_BASE_URL=
VITE_API_BASE_COMMON=

# Static resources & updates
VITE_UPDATES_INFO_URL=
VITE_SOFTWARE_LIST_URL=
VITE_DEV_ENV_LIST_URL=
VITE_LOWCODE_EDITOR_URL=
VITE_DEFAULT_USER_AVATAR_URL=

# Demo page only — optional API token for /views/demo
# VITE_DEMO_API_TOKEN=

# WeChat mini-program (optional, for payment QR)
VITE_WECHAT_PRODUCT_ID=

# Website footer ICP filing number (optional, hidden when empty)
# VITE_SITE_ICP_NUMBER=

# Documentation links (optional, hidden when empty)
VITE_DOC_SOFTWARE_OFFICIAL=
VITE_DOC_INTRO=
VITE_DOC_VOICE_WAKEUP=
VITE_DOC_SWITCH_PROXY=
VITE_DOC_PROXY_CERT=
VITE_DOC_CODE_SNIPPET=
VITE_DOC_OLLAMA_GUIDE=

# Electron main process (set when launching Electron, not read by Vite)
# UWORK_REMOTE_ORIGIN=
# UWORK_UPDATES_INFO_URL=
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_ASR_REGION=ap-beijing
# TRANSFER_SOURCE_PATH=
