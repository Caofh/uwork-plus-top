{
  "name": "uworkplus-lowcode-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Visual low-code page editor for UworkPlus",
  "repository": {
    "type": "git",
    "url": "https://gitee.com/redorc/uwork-plus-top.git",
    "directory": "uworkplus-code-lowcodeEditor"
  },
  "repositoryGithub": "https://github.com/Caofh/uwork-plus-top.git",
  "license": "MIT",
  "author": "UworkPlus Contributors",
  "engines": {
    "node": "22.18.0"
  },
  "scripts": {
    "preinstall": "node -e \"if(process.version !== 'v22.18.0'){console.error('Node.js version must be exactly 22.18.0, current version:', process.version); process.exit(1);}\"",
    "dev": "vite --mode development",
    "build": "run-p \"build-only {@}\" --",
    "build:test": "yarn build --mode test",
    "build:pre": "yarn build --mode pre",
    "build:prod": "yarn build --mode production",
    "publishAli2": "npm run build && node ../scripts/scp-deploy.js dist /data/web/pro/lowcodeEditor",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --fix",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.2",
    "@vueuse/core": "13.9.0",
    "axios": "^1.11.0",
    "element-plus": "2.11.1",
    "js-cookie": "3.0.5",
    "lodash": "4.17.21",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "vuedraggable": "2.24.3"
  },
  "devDependencies": {
    "@tsconfig/node22": "^22.0.2",
    "@types/js-cookie": "3.0.6",
    "@types/node": "^22.18.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "10.4.21",
    "eslint": "^9.31.0",
    "eslint-plugin-vue": "~10.3.0",
    "husky": "^9.1.7",
    "jiti": "^2.4.2",
    "lint-staged": "^16.1.6",
    "npm-run-all2": "^8.0.4",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "sass-embedded": "1.93.0",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.0",
    "unplugin-auto-import": "20.1.0",
    "unplugin-vue-components": "29.0.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vue-tsc": "^3.0.4"
  }
}
