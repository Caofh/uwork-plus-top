# pnpm 配置文件

# 自动安装 peer dependencies
auto-install-peers=true

# 严格 peer dependencies 检查
strict-peer-dependencies=false

# 保存精确版本号
save-exact=true

# 使用淘宝镜像源（可选，中国用户推荐）
# registry=https://registry.npmmirror.com/

# 启用 pnpm 的严格模式
strict-peer-dependencies=false

# 禁用自动安装 peer dependencies 的警告
auto-install-peers=true

# 强制检查 engines 版本要求
engine-strict=true
